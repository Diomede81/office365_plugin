{
  "$schema": "https://openclaw.ai/schemas/plugin-manifest.json",
  "id": "office365",
  "name": "Office 365",
  "version": "1.0.0",
  "description": "Microsoft Office 365 integration - Teams, Outlook, Calendar with persistent sessions",
  "author": "Luca Licata",
  "license": "MIT",
  "main": "index.js",
  "type": "channel",
  "channels": ["teams"],
  "configSchema": {
    "type": "object",
    "properties": {
      "clientId": {
        "type": "string",
        "description": "Azure App Client ID"
      },
      "tenantId": {
        "type": "string",
        "description": "Azure Tenant ID"
      },
      "tokenFile": {
        "type": "string",
        "description": "Path to tokens.json file"
      },
      "webhookUrl": {
        "type": "string",
        "description": "Public webhook URL for Microsoft Graph subscriptions"
      }
    },
    "required": []
  }
}
